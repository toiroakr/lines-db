{
  "name": "@toiroakr/lines-db",
  "version": "0.9.1",
  "description": "A database implementation that treats JSONL files as tables using SQLite",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "lines-db": "./bin/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "database",
    "jsonl",
    "sqlite",
    "seed-data"
  ],
  "author": "toiroakr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toiroakr/lines-db.git"
  },
  "bugs": {
    "url": "https://github.com/toiroakr/lines-db/issues"
  },
  "homepage": "https://github.com/toiroakr/lines-db#readme",
  "devDependencies": {
    "@types/node": "24.12.2",
    "tsdown": "0.21.9",
    "type-fest": "5.6.0",
    "typescript": "5.9.3",
    "valibot": "1.3.1",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "valibot": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    }
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "commander": "^14.0.2",
    "tsx": "^4.19.2"
  }
}
