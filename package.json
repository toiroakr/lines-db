{
  "name": "@toiroakr/lines-db-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for lines-db library and related packages",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter @toiroakr/lines-db build",
    "test": "pnpm --filter @toiroakr/lines-db-tests-unit test",
    "test:runtime": "pnpm test:cjs",
    "test:cjs": "pnpm --filter @toiroakr/lines-db-tests-runtime-cjs test",
    "test:all": "pnpm test && pnpm test:runtime",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "example": "pnpm --filter @toiroakr/lines-db-examples example",
    "example:validation": "pnpm --filter @toiroakr/lines-db-examples example:validation",
    "example:json": "pnpm --filter @toiroakr/lines-db-examples example:json",
    "example:datadir": "pnpm --filter @toiroakr/lines-db-examples example:datadir",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm test && changeset publish"
  },
  "keywords": [
    "database",
    "jsonl",
    "sqlite",
    "seed-data"
  ],
  "author": "toiroakr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toiroakr/lines-db.git"
  },
  "bugs": {
    "url": "https://github.com/toiroakr/lines-db/issues"
  },
  "homepage": "https://github.com/toiroakr/lines-db#readme",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/js": "9.39.4",
    "@toiroakr/lines-db": "workspace:*",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "lefthook": "2.1.6",
    "prettier": "3.8.3",
    "typescript-eslint": "8.59.0"
  }
}
